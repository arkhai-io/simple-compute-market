# BuildKit per-Dockerfile ignore (requires DOCKER_BUILDKIT=1)
# Deny everything, then allowlist what the build needs.

*

# ── arkhai-vms-provisioning ───────────────────────────────────────
!domains/
!domains/vms/
!domains/vms/provisioning/
!domains/vms/provisioning/service/
!domains/vms/provisioning/service/pyproject.toml
!domains/vms/provisioning/service/uv.lock
!domains/vms/provisioning/service/src/**

# ── Internal package wheels (built by make dist before docker build) ────────
!.dist/

# ── domains/vms/provisioning/iac (Ansible only, no Terraform) ───────────
!domains/vms/provisioning/iac/
!domains/vms/provisioning/iac/ansible/**

# Exclude sensitive / generated files inside ansible/
domains/vms/provisioning/iac/ansible/inventory/management-vars.yaml
domains/vms/provisioning/iac/ansible/keys/
domains/vms/provisioning/iac/ansible/ansible.log

# ── Global excludes ─────────────────────────────────────────────────
**/.git
**/.venv
**/__pycache__
**/.env*
**/terraform/
**/.DS_Store
