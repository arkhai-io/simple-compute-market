{
  "version": 1,
  "description": "Recorded verify/consume session every middleware implementation (Python, TypeScript, Rust) must reproduce. The gate runs in synchronous mode (flush_interval_seconds = 0) so each allowed request makes exactly one consume call and the trace is deterministic across languages. Steps assert the gate's HTTP-facing decision plus the number of verify/consume calls the step triggered, which pins the verify cache (a repeat key skips verify) and the exhausted-key short-circuit (a drained key denies without a consume call).",
  "config": {
    "amount_per_request": 1,
    "verify_ttl_seconds": 30,
    "low_balance_threshold": 0,
    "flush_interval_seconds": 0,
    "purchase": {
      "service_name": "weather-api",
      "listing_id": "lst-weather-1",
      "storefront_url": "http://tokens-storefront:8000",
      "registry_url": "http://api-tokens-registry:8080"
    }
  },
  "service": {
    "verify": {
      "ak_live": [{"valid": true, "status": "active", "balance": 3}],
      "ak_revoked": [{"valid": false, "status": "revoked", "balance": 0}],
      "ak_ghost": [{"valid": false, "status": null, "balance": 0}]
    },
    "consume": {
      "ak_live": [
        {"status": 200, "body": {"ok": true, "consumed": 1, "balance": 2}},
        {"status": 200, "body": {"ok": true, "consumed": 1, "balance": 1}},
        {"status": 200, "body": {"ok": true, "consumed": 1, "balance": 0}},
        {"status": 402, "body": {"error": "insufficient_credits", "balance": 0}}
      ]
    }
  },
  "steps": [
    {
      "name": "no Authorization header is rejected before any service call",
      "authorization": null,
      "expect": {"allowed": false, "status": 401, "error": "missing_api_key", "purchase": false},
      "verify_calls": 0,
      "consume_calls": 0
    },
    {
      "name": "a bearer with no key id is invalid",
      "authorization": "Bearer .nokey",
      "expect": {"allowed": false, "status": 401, "error": "invalid_api_key", "purchase": false},
      "verify_calls": 0,
      "consume_calls": 0
    },
    {
      "name": "first live request verifies then consumes",
      "authorization": "Bearer ak_live.s3cr3t",
      "expect": {"allowed": true, "status": 200},
      "verify_calls": 1,
      "consume_calls": 1
    },
    {
      "name": "second live request reuses the cached verify",
      "authorization": "Bearer ak_live.s3cr3t",
      "expect": {"allowed": true, "status": 200},
      "verify_calls": 0,
      "consume_calls": 1
    },
    {
      "name": "third live request drains the balance to zero",
      "authorization": "Bearer ak_live.s3cr3t",
      "expect": {"allowed": true, "status": 200},
      "verify_calls": 0,
      "consume_calls": 1
    },
    {
      "name": "fourth request hits 402 from the service and surfaces the purchase pointer",
      "authorization": "Bearer ak_live.s3cr3t",
      "expect": {"allowed": false, "status": 402, "error": "insufficient_credits", "purchase": true},
      "verify_calls": 0,
      "consume_calls": 1
    },
    {
      "name": "an exhausted key short-circuits without re-consuming",
      "authorization": "Bearer ak_live.s3cr3t",
      "expect": {"allowed": false, "status": 402, "error": "insufficient_credits", "purchase": true},
      "verify_calls": 0,
      "consume_calls": 0
    },
    {
      "name": "a revoked key is 403 and never consumes",
      "authorization": "Bearer ak_revoked.s3cr3t",
      "expect": {"allowed": false, "status": 403, "error": "key_revoked", "purchase": true},
      "verify_calls": 1,
      "consume_calls": 0
    },
    {
      "name": "an unknown key is 401 invalid and never consumes",
      "authorization": "Bearer ak_ghost.s3cr3t",
      "expect": {"allowed": false, "status": 401, "error": "invalid_api_key", "purchase": false},
      "verify_calls": 1,
      "consume_calls": 0
    }
  ]
}
