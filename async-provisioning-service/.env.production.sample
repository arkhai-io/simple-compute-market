# ============================================================
# Async Provisioning Service — production / deployed canary
# ============================================================

HOST=0.0.0.0
PORT=8081
LOG_LEVEL=info

# Database / queue
DATABASE_URL=postgresql+psycopg2://postgres:postgres@<postgres-host>:5432/provisioning
REDIS_URL=redis://<redis-host>:6379/0
REDIS_QUEUE_NAME=provisioning_jobs

# Ansible / inventory
ANSIBLE_TIMEOUT_SECONDS=1800
DEFAULT_VM_HOST=ww1
# PROVISIONING_REPO_ROOT=/app
# PLAYBOOK_PATH=/app/compute-provisioning-iac/ansible/playbooks/single-tenant/vm-operations.yaml
# INVENTORY_PATH=/app/compute-provisioning-iac/ansible/inventory/hosts

# ZeroTier
ZEROTIER_NETWORK=<network-id>

# Authentication
ENABLE_AUTH=true
AUTH_FAIL_OPEN=false
REGISTRY_URL=http://<registry-zerotier-ip>:8080
REGISTRY_CACHE_TTL_SECONDS=300
REGISTRY_CACHE_MAX_SIZE=256

# Rate limiting
ENABLE_RATE_LIMITING=true
RATE_LIMIT_REQUESTS_PER_MINUTE=30

# FRP
FRP_SERVER_ADDR=<frp-server-ip>
FRP_DOMAIN=<frp-domain>
FRP_DASHBOARD_PASSWORD=<frp-dashboard-password>

# Secrets injected at deploy time
SSH_PRIVATE_KEY=
MANAGEMENT_VARS_YAML=
