HOST=0.0.0.0
PORT=8081
LOG_LEVEL=info

# Database Configuration
# PostgreSQL (production)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/provisioning
# SQLite (development) - uncomment to use
# DATABASE_URL=sqlite:///provisioning.db

# Redis Queue Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_QUEUE_NAME=provisioning_jobs

# Ansible Configuration
# These paths are auto-resolved at runtime:
#   - Local dev: walks up from __file__ to find compute-provisioning-iac/
#   - Docker:    resolves to /app/compute-provisioning-iac/...
# Override only if your layout differs from the default.
# PROVISIONING_REPO_ROOT=/absolute/path/to/repo
# PLAYBOOK_PATH=/absolute/path/to/compute-provisioning-iac/ansible/playbooks/single-tenant/vm-operations.yaml
# INVENTORY_PATH=/absolute/path/to/compute-provisioning-iac/ansible/inventory/hosts
ANSIBLE_TIMEOUT_SECONDS=1800
DEFAULT_VM_HOST=vm1

# ZeroTier Network Configuration
ZEROTIER_NETWORK=5170efff3f3bf6ba

# Authentication (ERC-8004 Agent Registry)
ENABLE_AUTH=false
REGISTRY_URL=http://localhost:8080
REGISTRY_CACHE_TTL_SECONDS=300
REGISTRY_CACHE_MAX_SIZE=256

# Rate Limiting (per-agent)
ENABLE_RATE_LIMITING=false
RATE_LIMIT_REQUESTS_PER_MINUTE=30

# FRP Configuration
FRP_SERVER_ADDR=10.10.10.10
FRP_DOMAIN=example.com
FRP_DASHBOARD_PASSWORD=password
