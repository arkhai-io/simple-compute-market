# ============================================================
# Agent — production / deployed canary
# ============================================================

# --- Core Agent Identity ---
GEMINI_API_KEY=
BASE_URL_OVERRIDE=http://{ZEROTIER_IP}:8000/
PORT=8000
AGENT_DB_PATH=/var/lib/market/agent.db
AGENT_ID=agent_prod_canary
LOG_FILE_PATH=/var/log/market/agent.log
AUTO_REGISTER=true
ENABLE_EVENT_QUEUE=false

# --- On-chain Registry Addresses ---
IDENTITY_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000001
REPUTATION_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000002
VALIDATION_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000003
CHAIN_ID=84532
REGISTRY_URL=http://<registry-zerotier-ip>:8080/
CHAIN_RPC_URL=wss://<rpc-provider>
AGENT_PRIV_KEY=0x
AGENT_WALLET_ADDRESS=0x

# --- Alkahest ---
# Use the deployed chain directly. Do not set ALKAHEST_ADDRESS_CONFIG_PATH unless CHAIN_NAME=anvil.
CHAIN_NAME=base_sepolia
TOKEN_REGISTRY_PATH=/app/core/agent/app/data/token_registry_base_sepolia.json

# --- Networking ---
SSH_PUBLIC_KEY="ssh-ed25519 AAAA... canary@example.com"
ZEROTIER_NETWORK=<network-id>

# --- Provisioning ---
PROVISIONING_MODE=http
PROVISIONING_SERVICE_URL=http://<provisioner-zerotier-ip>:8081
PROVISIONING_TIMEOUT=3600
PROVISIONING_POLL_INTERVAL=15
DEFAULT_VM_HOST=ww1
RESOURCE_CHECK_INTERVAL=60

# --- FRP ---
FRP_SERVER_ADDR=<frp-server-ip>
FRP_DOMAIN=<frp-domain>
FRP_DASHBOARD_PASSWORD=<frp-dashboard-password>

# --- Negotiation ---
NEGOTIATION_POLICY_MODE=bisection
