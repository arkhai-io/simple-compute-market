# --- Core Agent Identity ---
# API key for the Gemini LLM backing the ADK agent
GEMINI_API_KEY=AIxx
# Public URL this agent advertises to peers (used in A2A agent card and offer messages)
BASE_URL_OVERRIDE=http://localhost:8000/
PORT=8000
# SQLite database for orders, policies, and negotiation threads (relative to process CWD = core/)
AGENT_DB_PATH=./agent.db
AGENT_ID=agent_xxx
# Log file path (relative to process CWD = core/)
LOG_FILE_PATH=./logs/maker_agent.log
# Automatically register this agent on-chain at startup
AUTO_REGISTER=true

# --- On-chain Registry Addresses ---
IDENTITY_REGISTRY_ADDRESS=0x8004AA63c570c570eBF15376c0dB199918BFe9Fb
REPUTATION_REGISTRY_ADDRESS=0x8004bd8daB57f14Ed299135749a5CB5c42d341BF
VALIDATION_REGISTRY_ADDRESS=0x8004Cb1BF31DAf7788923b405b754f57acEB4272
# URL of the off-chain indexer (ERC-8004 order registry)
REGISTRY_URL=http://localhost:8080/
# WebSocket RPC for on-chain event listening and tx submission
CHAIN_RPC_URL=ws://127.0.0.1:8545
# Private key and address of this agent's wallet (used for signing attestations)
AGENT_PRIV_KEY=0x4bbbf85ce3377467afe5d46f804f221813b2bb87f24d81f60f1fcdbf7cbf4356
AGENT_WALLET_ADDRESS=0x14dC79964da2C08b23698B3D3cc7Ca32193d9955
# --- Alkahest (Escrow / Payment) ---
# "anvil" = local dev; "base-sepolia" / "base" for testnets/mainnet
CHAIN_NAME=anvil
# For CHAIN_NAME=anvil, provide: path to the deployed contract addresses JSON
# ALKAHEST_ADDRESS_CONFIG_PATH=../core/agent/app/data/alkahest_anvil_addresses.json
# Token registry maps symbol → contract address for each supported payment token
# Relative to CWD when running from core/agent/
TOKEN_REGISTRY_PATH=./app/data/token_registry_docker_compose.json

# --- Networking ---
# Ed25519 public key injected into provisioned VMs so the buyer can SSH in
SSH_PUBLIC_KEY="ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIDemoPublicKeyForComputeAccess alice@example.com"
# ZeroTier network ID — agents must be joined to the same network to reach each other
ZEROTIER_NETWORK=5170efff3f3bf6ba
# PROVISIONING_MODE controls which provisioning client is used:
#   http    — POST/poll to PROVISIONING_SERVICE_URL (default, requires running service)
#   ansible — run ansible-playbook directly (requires compute-provisioning-iac/ and a VM host)
#   mock    — deterministic test double, no I/O (for CI / unit tests)
PROVISIONING_MODE=mock

# --- HTTP mode (PROVISIONING_MODE=http) ---
# URL of the async-provisioning-service REST API
PROVISIONING_SERVICE_URL=http://localhost:8085

# --- Ansible mode (PROVISIONING_MODE=ansible) ---
# KVM host name as defined in compute-provisioning-iac/ansible/inventory/hosts
DEFAULT_VM_HOST=ww1
# How often (seconds) to poll VM host availability (default: 300)
RESOURCE_CHECK_INTERVAL=60

# --- FRP (required for both http and ansible modes) ---
# External reverse-proxy for SSH access to provisioned VMs
FRP_SERVER_ADDR=10.10.10.10
FRP_DOMAIN=example.com
FRP_DASHBOARD_PASSWORD=password

# --- Arkhai RL Policy Configuration ---
# Number of GPU node type slots in the observation vector. Must match the trained checkpoint.
# obs_dim = 12 + 3 * ARKHAI_NODE_TYPES (default 5 → obs_dim=27)
# ARKHAI_NODE_TYPES=5
# Maps GPU model names to observation vector slot indices (comma-separated NAME:INDEX pairs).
# Unrecognised GPU types are silently skipped — ensure all active GPU types are listed.
# Default: H200:0, Tesla V100:1, RTX 5080:2, RTX A5000:3, RTX 4090:4
# ARKHAI_GPU_SLOT_MAP="H200:0, Tesla V100:1, RTX 5080:2, RTX A5000:3, RTX 4090:4"
# Maximum GPU units per slot used to normalise request quantities in the obs vector
# ARKHAI_JOB_GPU_NODES="10,10,10,10,10"
# Override model paths for the MakeOffer RL policies (reserved for future use, not currently seeded)
# ARKHAI_SELLER_MODEL_PATH=models/arkhai_negotiator_seller.pt
# ARKHAI_BUYER_MODEL_PATH=models/arkhai_negotiator_buyer.pt

# --- Negotiation Policy ---
# "bisection" (default) uses hand-coded price_interval_concession
# "rl" uses puffer Arkhai bilateral negotiation checkpoints
NEGOTIATION_POLICY_MODE=bisection
# Override model checkpoint paths (optional — defaults resolve automatically from the policy module).
# Relative paths are resolved relative to domain/compute/agent/app/policy/, NOT the process CWD.
# Use "models/<name>.pt" for the bundled checkpoints, or an absolute path for a custom checkpoint.
# ARKHAI_NEGOTIATOR_SELLER_MODEL_PATH=models/arkhai_negotiator_seller.pt
# ARKHAI_NEGOTIATOR_BUYER_MODEL_PATH=models/arkhai_negotiator_buyer.pt
