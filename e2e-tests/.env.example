# .env.example
# ---------------------------------------------------------------------------
# Copy to .env and fill in for local development.
# In CI/CD these are set directly in the pipeline environment.
#
# Dynaconf prefix: ARKHAI_
# Nested keys use double-underscore separator: ARKHAI_RPC__URL
# ---------------------------------------------------------------------------

# --- dynaconf control ---
ENV_FOR_DYNACONF=default
# Comma-separated list of active profiles (maps to config-<name>.yml files)
ACTIVE_PROFILES=local
# Absolute path to the directory containing config.yml and profile files
CONFIG_DIRECTORY=/path/to/config