# config.registry.env — env file for compose/registry.yml.
#
# Copy to config.registry.env and fill in every REPLACE_WITH_* value
# before bringing the registry stack up. See docs/indexer-quickstart.md
# for full schema docs.
#
# IMPORTANT: keep REGISTRY_BOOTSTRAP_API_KEY in sync with the matching
# [registry.auth] entry in your storefront / buyer TOML — they must be
# byte-equal.

# --- Chain ---
# Base Sepolia.
CHAIN_ID=84532

# IMPORTANT: the registry calls eth_getLogs in 500-block chunks to index
# historical agent registrations. Pick an RPC provider that supports
# eth_getLogs over ranges of at least 500 blocks:
#
#   - https://sepolia.base.org    — public Base RPC, free, 2048-block
#                                   window, no auth. Rate-limited per
#                                   IP; fine for low-throughput indexers.
#   - Alchemy PAYG (paid)         — 10k-block window. Free tier caps at
#                                   10 blocks and will reject every
#                                   request the indexer makes.
#   - Infura / dRPC / BlockPi     — most paid tiers support >= 500.
#
# The storefront's RPC (in config.seller.toml) is independent and only
# does single-block eth_call traffic, so free Alchemy works there.
RPC_URL=https://REPLACE_WITH_YOUR_BASE_SEPOLIA_RPC_URL

# --- ERC-8004 contract addresses (Base Sepolia) ---
IDENTITY_REGISTRY_ADDRESS=0x8004A818BFB912233c491871b3d84c89A494BD9e
REPUTATION_REGISTRY_ADDRESS=0x8004B663056A597Dffe9eCcC1965A193B7388713
VALIDATION_REGISTRY_ADDRESS=0x8004Cb1BF31DAf7788923b405b754f57acEB4272

# First-sync start block. Without this the indexer only walks the last
# 1000 blocks on first boot and silently drops any agent registered
# earlier. Set to (or below) the IdentityRegistry deployment block.
REGISTRY_START_BLOCK=41707000

# --- HTTP server ---
PORT=8080
HOST=0.0.0.0

# --- Bearer-token auth (private indexer) ---
# When true, every publish/query needs `Authorization: Bearer <key>` with
# a key from the api_keys table.
REGISTRY_REQUIRE_API_KEY=true

# Used to mint/revoke per-user keys at POST /admin/api-keys. Generate
# with e.g. `openssl rand -hex 32`. Never share with sellers/buyers.
REGISTRY_ADMIN_API_KEY=REPLACE_WITH_RANDOM_ADMIN_SECRET

# Seeded into the api_keys table on first boot if the table is empty.
# Use this as the shared seller/buyer bearer until you mint per-user
# keys via /admin/api-keys. Generate with e.g. `openssl rand -hex 32`.
# Must match the value in the storefront/buyer's [registry.auth] block.
REGISTRY_BOOTSTRAP_API_KEY=REPLACE_WITH_RANDOM_BOOTSTRAP_SECRET

# --- Misc ---
LOG_LEVEL=info
ENABLE_HEALTH_CHECKS=false
HEARTBEAT_TTL_SECS=60
