# config.registry.env — env file for compose/registry.yml.
#
# Copy to config.registry.env and fill in every REPLACE_WITH_* value
# before bringing the registry stack up. See docs/indexer-quickstart.md
# for full schema docs.
#
# IMPORTANT: keep REGISTRY_BOOTSTRAP_API_KEY in sync with the matching
# [registry.auth] entry in your storefront / buyer TOML — they must be
# byte-equal.

# --- HTTP server ---
PORT=8080
HOST=0.0.0.0

# --- Bearer-token auth ---
# Read access (discovery, lookups) and write access (publish/update/
# delete listings, heartbeat) gate independently. Keys carry a scope;
# a write key implies read. Common postures:
#   both true       private indexer — buyers get read keys, sellers write
#   write only      open market — public discovery, vetted publishing
#   both false      fully public — drop the key vars below
REGISTRY_REQUIRE_READ_API_KEY=true
REGISTRY_REQUIRE_WRITE_API_KEY=true

# Used to mint/revoke per-user keys at POST /admin/api-keys (pass
# `scope: read|write` in the body). Generate with e.g.
# `openssl rand -hex 32`. Never share with sellers/buyers.
REGISTRY_ADMIN_API_KEY=REPLACE_WITH_RANDOM_ADMIN_SECRET

# Seeded into the api_keys table (write scope) on first boot if the
# table is empty. Use this as the shared seller/buyer bearer until you
# mint per-user keys via /admin/api-keys. Generate with e.g.
# `openssl rand -hex 32`. Must match the storefront/buyer's
# [registry.auth] block.
REGISTRY_BOOTSTRAP_API_KEY=REPLACE_WITH_RANDOM_BOOTSTRAP_SECRET

# --- Misc ---
LOG_LEVEL=info
ENABLE_HEALTH_CHECKS=false
HEARTBEAT_TTL_SECS=60
