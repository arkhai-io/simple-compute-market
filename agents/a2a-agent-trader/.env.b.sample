# Agent Configuration - Taker Agent
# Copy this file to .env.b and customize as needed
# This agent will discover and accept market orders from the registry

# Agent Identity
AGENT_ID=taker_agent
PORT=8001
BASE_URL_OVERRIDE=http://localhost:8001

# Remote Agent Configuration (points to maker agent)
REMOTE_AGENT_PORT=8000
REMOTE_AGENT_URL_OVERRIDE=http://localhost:8000

# MCP Server
MCP_SERVER_URL=http://localhost:8080/mcp

# Blockchain Configuration (optional - for on-chain features)
# CHAIN_RPC_URL=
# AGENT_PRIV_KEY=
# AGENT_WALLET_ADDRESS=

# Google GenAI Configuration
GOOGLE_GENAI_USE_VERTEXAI=False

# Policy Database (separate DB for taker agent)
POLICY_DB_PATH=/tmp/policies_taker.db

# Event Configuration
EVENT_VALIDATION_MODE=warn
ENABLE_REDIS_INGEST=false
REDIS_URL=redis://localhost:6379
REDIS_CHANNELS=events:*
ENABLE_EVENT_QUEUE=true

# Market Provider
MARKET_PROVIDER=static

# Logging
LOG_LEVEL=INFO
# LOG_FILE_PATH=

# Token Registry
TOKEN_REGISTRY_PATH=app/data/token_registry.json

# SSH Public Key (for compute provisioning)
SSH_PUBLIC_KEY=ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIDemoPublicKeyForComputeAccess demo@example

# Auto-registration Settings
AUTO_REGISTER=false
INDEXER_URL=http://localhost:8080
# IDENTITY_REGISTRY_ADDRESS=
# ONCHAIN_AGENT_ID=

# Registry Discovery Settings
ENABLE_REGISTRY_DISCOVERY=true
REGISTRY_ORDER_TIMEOUT=30
MAX_DISCOVERY_AGENTS=10
