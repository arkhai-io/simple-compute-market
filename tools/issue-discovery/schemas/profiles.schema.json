{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "profiles"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "profiles": {
      "type": "array",
      "items": { "$ref": "#/$defs/profile" }
    }
  },
  "$defs": {
    "profile": {
      "type": "object",
      "required": ["id", "phase_file", "phases"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "description": { "type": "string" },
        "phase_file": { "type": "string", "minLength": 1 },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "phases": {
          "type": "array",
          "items": { "$ref": "#/$defs/id" },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_\\-]*$"
    }
  }
}
