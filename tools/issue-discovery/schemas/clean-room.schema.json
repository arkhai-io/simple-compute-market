{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "sequences"],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "sequences": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "steps"],
        "properties": {
          "id": {
            "$ref": "#/$defs/id"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "steps": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/step"
            }
          }
        }
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]*$"
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "mode", "continue_on_failure"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": ["strict", "continue"]
        },
        "workarounds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "continue_on_failure": {
          "type": "boolean"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "mode": {
                "const": "continue"
              }
            },
            "required": ["mode"]
          },
          "then": {
            "required": ["workarounds"]
          }
        },
        {
          "if": {
            "properties": {
              "mode": {
                "const": "strict"
              }
            },
            "required": ["mode"]
          },
          "then": {
            "not": {
              "required": ["workarounds"]
            }
          }
        }
      ]
    }
  }
}
