FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    make \
    curl \
    rsync \
    && rm -rf /var/lib/apt/lists/*

ARG INSTALLER_URL
RUN if [ -n "$INSTALLER_URL" ]; then \
      curl -sSL "$INSTALLER_URL" -o /tmp/market-installer.sh; \
    fi

COPY market-installer.sh /tmp/market-installer.sh

RUN bash /tmp/market-installer.sh

ENV PATH="$HOME/.local/bin:$PATH"

RUN market --help

CMD ["/bin/bash"]
